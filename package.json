{
  "name": "@beauty-diagram/cli",
  "version": "0.1.2",
  "private": false,
  "description": "Beauty Diagram CLI — beautify, export, and share Mermaid / PlantUML diagrams from the command line.",
  "bin": {
    "bd": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "module",
